<!DOCTYPE html>
<html lang="en-GB">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAG Simulator</title>
    <style>
        /* General Body Styling */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f4f7f6;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            box-sizing: border-box;
        }

        /* Main Container */
        .rag-simulator-container {
            background-color: #ffffff;
            border-radius: 12px;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
            padding: 30px;
            max-width: 1000px;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr;
            gap: 25px;
        }

        h1 {
            color: #005073; /* Deloitte blue */
            text-align: center;
            margin-bottom: 30px;
            font-size: 2.2em;
            font-weight: 600;
        }

        h2 {
            color: #007bff; /* A lighter blue for section titles */
            margin-top: 0;
            margin-bottom: 15px;
            font-size: 1.5em;
            border-bottom: 2px solid #e0e0e0;
            padding-bottom: 8px;
        }

        /* Section Styling */
        .rag-step {
            background-color: #f9f9f9;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 20px;
            transition: all 0.3s ease;
        }

        .rag-step.active {
            border-color: #007bff;
            box-shadow: 0 0 15px rgba(0, 123, 255, 0.1);
        }

        /* Input and Button */
        textarea {
            width: calc(100% - 20px);
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 1em;
            min-height: 80px;
            resize: vertical;
            margin-bottom: 15px;
        }

        button {
            background-color: #007bff;
            color: white;
            padding: 12px 25px;
            border: none;
            border-radius: 6px;
            font-size: 1.1em;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.2s ease;
            display: block;
            width: fit-content;
            margin: 0 auto;
        }

        button:hover {
            background-color: #0056b3;
            transform: translateY(-2px);
        }

        button:disabled {
            background-color: #cccccc;
            cursor: not-allowed;
            transform: none;
        }

        /* Vector Database Display */
        .vector-db-item {
            background-color: #e9f7ff;
            border: 1px solid #b3e0ff;
            border-radius: 6px;
            padding: 10px 15px;
            margin-bottom: 8px;
            font-size: 0.9em;
            line-height: 1.4;
            transition: background-color 0.2s ease, border-color 0.2s ease;
        }

        .vector-db-item.retrieved {
            background-color: #d4edda; /* Greenish for retrieved */
            border-color: #28a745;
            font-weight: 500;
        }

        /* Retrieved Chunks Display */
        #retrievedChunksContainer .chunk-item {
            background-color: #d1ecf1;
            border: 1px solid #bee5eb;
            border-left: 5px solid #17a2b8;
            border-radius: 6px;
            padding: 12px 15px;
            margin-bottom: 10px;
            font-size: 0.95em;
            line-height: 1.5;
        }

        /* Answer Display */
        #generatedAnswer {
            background-color: #e2f0d9; /* Light green for answer */
            border: 1px solid #c3e6cb;
            border-left: 5px solid #28a745;
            border-radius: 8px;
            padding: 15px;
            font-size: 1.1em;
            line-height: 1.6;
            min-height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            font-weight: 500;
            color: #155724;
        }

        #statusMessage {
            text-align: center;
            margin-top: 15px;
            font-style: italic;
            color: #666;
            min-height: 20px;
        }

        /* Animation for processing */
        .processing::after {
            content: ' .';
            animation: dots 1s steps(5, end) infinite;
        }

        @keyframes dots {
            0%, 20% {
                color: rgba(0,0,0,0);
                text-shadow:
                    .25em 0 0 rgba(0,0,0,0),
                    .5em 0 0 rgba(0,0,0,0);
            }
            40% {
                color: #666;
                text-shadow:
                    .25em 0 0 rgba(0,0,0,0),
                    .5em 0 0 rgba(0,0,0,0);
            }
            60% {
                text-shadow:
                    .25em 0 0 #666,
                    .5em 0 0 rgba(0,0,0,0);
            }
            80%, 100% {
                text-shadow:
                    .25em 0 0 #666,
                    .5em 0 0 #666;
            }
        }

        /* Responsive adjustments */
        @media (min-width: 768px) {
            .rag-simulator-container {
                grid-template-columns: 1fr 1fr;
            }
            .rag-step:nth-child(1), .rag-step:nth-child(2), .rag-step:nth-child(3), .rag-step:nth-child(4), .rag-step:nth-child(5), .rag-step:nth-child(6) {
                grid-column: span 1;
            }
            .rag-step:nth-child(1) { grid-column: 1 / 3; } /* Query input spans both columns */
            .rag-step:nth-child(6) { grid-column: 1 / 3; } /* Answer spans both columns */
        }
    </style>
</head>
<body>
    <div class="rag-simulator-container">
        <h1>RAG Simulator: Step-by-Step</h1>

        <!-- Step 1: User Query -->
        <div id="step1" class="rag-step active">
            <h2>1. User Query</h2>
            <p>Enter your question or topic below:</p>
            <textarea id="userQuery" placeholder="e.g., What is the capital of France?"></textarea>
            <button id="simulateButton" onclick="simulateRAG()">Simulate RAG</button>
            <div id="statusMessage"></div>
        </div>

        <!-- Step 2: Simulate Vectorisation -->
        <div id="step2" class="rag-step">
            <h2>2. Query Vectorisation (Simulated)</h2>
            <p>Your query is converted into a numerical vector representation.</p>
            <div id="vectorisationStatus" style="font-style: italic; color: #555;">Awaiting query...</div>
        </div>

        <!-- Step 3: Simulate Vector Database -->
        <div id="step3" class="rag-step">
            <h2>3. Vector Database Search (Simulated)</h2>
            <p>The query vector searches a database of pre-indexed document chunks.</p>
            <div id="vectorDatabaseDisplay">
                <!-- Sample chunks will be loaded here by JS -->
            </div>
        </div>

        <!-- Step 4: Retrieved Chunks -->
        <div id="step4" class="rag-step">
            <h2>4. Retrieved Chunks</h2>
            <p>The most relevant chunks are retrieved based on similarity.</p>
            <div id="retrievedChunksContainer">
                <p style="color: #888;">No chunks retrieved yet.</p>
            </div>
        </div>

        <!-- Step 5: LLM Generation (Simulated) -->
        <div id="step5" class="rag-step">
            <h2>5. LLM Generation (Simulated)</h2>
            <p>The Large Language Model (LLM) uses the query and retrieved chunks to formulate an answer.</p>
            <div id="llmStatus" style="font-style: italic; color: #555;">Awaiting retrieval...</div>
        </div>

        <!-- Step 6: Generated Answer -->
        <div id="step6" class="rag-step">
            <h2>6. Generated Answer</h2>
            <p>The final answer provided by the RAG system.</p>
            <div id="generatedAnswer">Your answer will appear here.</div>
        </div>
    </div>

    <script>
        // Simulated Vector Database (pre-indexed chunks)
        const vectorDatabase = [
            { id: 'doc1', text: 'The capital of France is Paris. Paris is known for its Eiffel Tower and Louvre Museum. It is a major European city.' },
            { id: 'doc2', text: 'London is the capital of the United Kingdom. It is famous for Buckingham Palace, the River Thames, and its rich history.' },
            { id: 'doc3', text: 'Retrieval-Augmented Generation (RAG) is an AI framework that enhances the capabilities of large language models (LLMs) by allowing them to access and incorporate external, up-to-date information during the generation process.' },
            { id: 'doc4', text: 'The process of RAG typically involves two main phases: retrieval and generation. First, relevant documents or data chunks are retrieved from a knowledge base. Second, an LLM uses these retrieved chunks along with the user query to generate a more informed response.' },
            { id: 'doc5', text: 'Artificial intelligence (AI) is a broad field of computer science concerned with building smart machines capable of performing tasks that typically require human intelligence.' },
            { id: 'doc6', text: 'Deloitte is one of the "Big Four" accounting firms and the largest professional services network in the world by revenue and number of professionals.' },
            { id: 'doc7', text: 'The River Seine flows through Paris, adding to its scenic beauty. Many famous landmarks are situated along its banks.' },
            { id: 'doc8', text: 'Machine learning is a subset of AI that enables systems to learn from data, identify patterns, and make decisions with minimal human intervention.' },
            { id: 'doc9', text: 'The primary benefit of RAG is that it reduces the likelihood of LLMs generating incorrect or outdated information (hallucinations) by grounding their responses in verified external data.' },
            { id: 'doc10', text: 'The United Kingdom is an island nation in northwestern Europe, comprising England, Scotland, Wales, and Northern Ireland.' }
        ];

        // Elements
        const userQueryInput = document.getElementById('userQuery');
        const simulateButton = document.getElementById('simulateButton');
        const statusMessage = document.getElementById('statusMessage');
        const vectorisationStatus = document.getElementById('vectorisationStatus');
        const vectorDatabaseDisplay = document.getElementById('vectorDatabaseDisplay');
        const retrievedChunksContainer = document.getElementById('retrievedChunksContainer');
        const llmStatus = document.getElementById('llmStatus');
        const generatedAnswerDiv = document.getElementById('generatedAnswer');

        const steps = ['step1', 'step2', 'step3', 'step4', 'step5', 'step6'];

        // Function to update active step styling
        function setActiveStep(stepId) {
            steps.forEach(id => {
                document.getElementById(id).classList.remove('active');
            });
            if (stepId) {
                document.getElementById(stepId).classList.add('active');
            }
        }

        // Load initial vector database display
        function loadVectorDatabaseDisplay() {
            vectorDatabaseDisplay.innerHTML = '<h3>Available Chunks:</h3>';
            vectorDatabase.forEach(chunk => {
                const div = document.createElement('div');
                div.className = 'vector-db-item';
                div.id = `chunk-${chunk.id}`;
                div.textContent = `[${chunk.id}] ${chunk.text.substring(0, 80)}...`;
                vectorDatabaseDisplay.appendChild(div);
            });
        }

        loadVectorDatabaseDisplay();

        async function simulateRAG() {
            const query = userQueryInput.value.trim();
            if (!query) {
                statusMessage.textContent = 'Please enter a query to simulate.';
                return;
            }

            // Reset UI
            simulateButton.disabled = true;
            statusMessage.textContent = '';
            vectorisationStatus.textContent = 'Awaiting query...';
            llmStatus.textContent = 'Awaiting retrieval...';
            generatedAnswerDiv.textContent = 'Your answer will appear here.';
            retrievedChunksContainer.innerHTML = '<p style="color: #888;">No chunks retrieved yet.</p>';
            document.querySelectorAll('.vector-db-item').forEach(item => item.classList.remove('retrieved'));

            // Step 1: User
